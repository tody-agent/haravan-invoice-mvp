{
  "name": "@haravan/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute haravan-invoice-mvp --local --file=schema.sql",
    "db:seed": "wrangler d1 execute haravan-invoice-mvp --local --file=seed.sql",
    "db:migrate:remote": "wrangler d1 execute haravan-invoice-mvp --remote --file=schema.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  }
}
